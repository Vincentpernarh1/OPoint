# ===========================================
# SUPABASE DATABASE CONFIGURATION
# ===========================================
# Get your credentials from: https://supabase.com/dashboard
# 1. Create a new project at https://supabase.com
# 2. Go to Settings > API
# 3. Copy your project URL and anon/public key below

SUPABASE_URL=
SUPABASE_ANON_KEY=

# ===========================================
# MTN MOBILE MONEY API CONFIGURATION
# ===========================================
# Get your credentials from: https://momodeveloper.mtn.com/

# MTN MoMo Base URL (sandbox or production)
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com/disbursement

# Your MTN MoMo User ID
MOMO_USER_ID=

# Your MTN MoMo API Key
MOMO_API_KEY=

# Your MTN MoMo Subscription Key
MOMO_SUBSCRIPTION_KEY=

# Target Environment (sandbox or production)
MOMO_TARGET_ENV=sandbox

# Callback Host (for receiving payment status updates)
CALLBACK_HOST=http://localhost:3001

# ===========================================
# APPLICATION SETTINGS
# ===========================================

# Approval Password for Payroll Processing
APPROVAL_PASSWORD=approve123

# Server Port
PORT=3001

# Node Environment (development, production)
NODE_ENV=development
